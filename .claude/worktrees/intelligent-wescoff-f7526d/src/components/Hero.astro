---
import ButtonExpand from "./ButtonExpand.astro";
---

<section class="hero">
  <div class="hero__inner container">
    <h1 class="hero__heading">
      <span class="hero__line" data-hero-line="1">I build pixel</span>
      <span class="hero__line" data-hero-line="2">perfect websites,</span>
      <span class="hero__line hero__italic" data-hero-line="3">one project at a time</span>
    </h1>
    <p class="hero__text" data-hero-text>Whether you're refreshing an outdated website or building something completely new, my approach stays the same. AI-enhanced workflow, clean interactions, and pixel-perfect execution that brings your brand to life.</p>
    <div class="hero__actions" data-hero-actions>
      <ButtonExpand href="/contact" label="Get Started" variant="accent" />
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";

  async function animateHero() {
    const line1 = document.querySelector('[data-hero-line="1"]') as HTMLElement;
    const line2 = document.querySelector('[data-hero-line="2"]') as HTMLElement;
    const line3 = document.querySelector('[data-hero-line="3"]') as HTMLElement;
    const text = document.querySelector('[data-hero-text]') as HTMLElement;
    const actions = document.querySelector('[data-hero-actions]') as HTMLElement;
    if (!line1 || !line2 || !line3 || !text || !actions) return;
    if (line1.dataset.animated) return;
    line1.dataset.animated = "true";

    /* Wait for fonts — prevents layout shift from font-swap */
    await document.fonts.ready;

    /* Split lines 1 & 2 into words */
    function splitIntoWords(el: HTMLElement) {
      const words = (el.textContent || "").split(" ");
      el.textContent = "";
      return words.map((word, i) => {
        const span = document.createElement("span");
        span.textContent = i < words.length - 1 ? word + " " : word;
        span.style.display = "inline-block";
        span.style.opacity = "0";
        el.appendChild(span);
        return span;
      });
    }

    const words1 = splitIntoWords(line1);
    line1.style.opacity = "1";
    const words2 = splitIntoWords(line2);
    line2.style.opacity = "1";

    /* Split line 3 into characters for typewriter */
    const line3Text = line3.textContent || "";
    line3.textContent = "";
    const chars = [...line3Text].map((char) => {
      const span = document.createElement("span");
      span.textContent = char;
      span.style.display = "inline-block";
      span.style.opacity = "0";
      if (char === " ") span.style.whiteSpace = "pre";
      line3.appendChild(span);
      return span;
    });
    line3.style.opacity = "1";

    const mm = gsap.matchMedia();
    mm.add("(prefers-reduced-motion: no-preference)", () => {
      const tl = gsap.timeline({ delay: 0.3 });

      /* Line 1: word by word from below */
      tl.fromTo(words1,
        { y: 40, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.6, stagger: 0.12, ease: "back.out(1.4)" }
      )

      /* Line 2: word by word from below */
      .fromTo(words2,
        { y: 40, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.6, stagger: 0.12, ease: "back.out(1.4)" },
        "-=0.2"
      )

      /* Line 3: typewriter — letter by letter */
      .to(chars, {
        opacity: 1,
        duration: 0.05,
        stagger: 0.06,
        ease: "none",
      }, "-=0.2")

      /* Paragraph fade in */
      .to(text, {
        opacity: 1,
        duration: 0.8,
        ease: "power2.out",
      }, "-=0.5")

      /* Button fade in */
      .to(actions, {
        opacity: 1,
        duration: 0.8,
        ease: "power2.out",
      }, "-=0.5");
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", animateHero);
  } else {
    animateHero();
  }
  document.addEventListener("astro:page-load", animateHero);
</script>

<style>
  .hero {
    padding-top: 15em;
    padding-bottom: 3.75em;
  }

  .hero__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 1272px;
    overflow: hidden;
  }

  .hero__heading {
    max-width: 1100px;
    font-family: var(--font-body);
    color: var(--color-primary);
    font-size: 8.125em;
    font-weight: 500;
    line-height: 1.2;
    margin: 0;
  }

  /* CSS hides content before JS loads — prevents font-swap flash */
  .hero__line {
    display: block;
    opacity: 0;
    white-space: nowrap;
  }

  .hero__italic {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -2px;
  }

  .hero__text {
    color: var(--color-primary-60);
    max-width: 700px;
    margin: 0 auto;
    padding-top: 1em;
    font-size: 1.125em;
    line-height: 1.3;
    letter-spacing: 0.4px;
    opacity: 0;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 2em;
    margin-top: 2em;
    opacity: 0;
  }

  @media (max-width: 991px) {
    .hero {
      padding-top: 10em;
      padding-bottom: 2em;
    }

    .hero__heading {
      font-size: 5em;
    }
  }

  @media (max-width: 767px) {
    .hero {
      padding-top: 8.75em;
      padding-bottom: 1.5em;
    }

    .hero__heading {
      font-size: 3.4375em;
      line-height: 1.1;
    }
  }

  @media (max-width: 479px) {
    .hero__heading {
      font-size: 3em;
      line-height: 1;
    }
  }

  /* Reduced motion — show content immediately */
  @media (prefers-reduced-motion: reduce) {
    .hero__line,
    .hero__text,
    .hero__actions {
      opacity: 1;
    }
  }
</style>
