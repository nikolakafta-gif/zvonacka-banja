---
import ButtonExpand from "./ButtonExpand.astro";

const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "";
const prefix = isHome ? "" : "/";

const navLinks = [
  { label: "Home", href: `${prefix}#home` },
  { label: "About me", href: `${prefix}#about` },
  { label: "Work", href: `${prefix}#work` },
  { label: "Testimonial", href: `${prefix}#testimonials` },
  { label: "FAQ", href: `${prefix}#faq` },
  { label: "Certificates", href: `${prefix}#certificates` },
  { label: "Blog", href: "/blog" },
];
---

<header class="navbar" id="home">
  <nav class="navbar__inner">
    <ul class="navbar__links">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="navbar__link">{link.label}</a>
        </li>
      ))}
    </ul>
    <div class="navbar__actions">
      <button class="navbar__menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <div class="navbar__burger">
          <div class="navbar__burger-line"></div>
          <div class="navbar__burger-line"></div>
          <div class="navbar__burger-line"></div>
        </div>
      </button>
      {isHome && <ButtonExpand href="/contact" label="Let's Collaborate" variant="dark" />}
    </div>
  </nav>

  <div class="navbar__mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="navbar__mobile-inner">
      <div class="navbar__mobile-links">
        {navLinks.map((link) => (
          <a href={link.href} class="navbar__mobile-link">{link.label}</a>
        ))}
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector('.navbar__menu-toggle');
  const menu = document.querySelector('.navbar__mobile-menu');
  const mobileLinks = document.querySelectorAll('.navbar__mobile-link');

  function openMenu() {
    mobileLinks.forEach((link, i) => {
      const el = link as HTMLElement;
      el.style.transitionDelay = `${0.15 + (mobileLinks.length - 1 - i) * 0.06}s`;
    });
    menu?.classList.add('is-open');
    menu?.setAttribute('aria-hidden', 'false');
    toggle?.classList.add('is-open');
    toggle?.setAttribute('aria-expanded', 'true');
    toggle?.setAttribute('aria-label', 'Close menu');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    mobileLinks.forEach(link => {
      (link as HTMLElement).style.transitionDelay = '0s';
    });
    menu?.classList.remove('is-open');
    menu?.setAttribute('aria-hidden', 'true');
    toggle?.classList.remove('is-open');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'Open menu');
    toggle?.classList.add('is-closing');
    document.body.style.overflow = '';
    setTimeout(() => toggle?.classList.remove('is-closing'), 350);
  }

  function toggleMenu() {
    menu?.classList.contains('is-open') ? closeMenu() : openMenu();
  }

  toggle?.addEventListener('click', toggleMenu);
  mobileLinks.forEach(link => link.addEventListener('click', closeMenu));
</script>


<style>
  @keyframes nav-slide-right {
    from { opacity: 0; transform: translateX(-40px); }
    to { opacity: 1; transform: none; }
  }

  @keyframes nav-slide-left {
    from { opacity: 0; transform: translateX(40px); }
    to { opacity: 1; transform: none; }
  }

  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 6em;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.9375em 1.25em;
  }

  .navbar__inner {
    max-width: 1520px;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5625em 0.9375em;
    border-radius: var(--radius-pill);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .navbar__links {
    display: inline-flex;
    align-items: center;
    gap: 0.375em;
    background-color: var(--color-primary-05);
    border: 1px solid var(--color-primary-05);
    border-radius: var(--radius-pill);
    padding: 0.25em 0.625em;
    animation: nav-slide-right 1s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  .navbar__links li {
    display: inline-flex;
  }

  .navbar__link {
    color: var(--color-primary-60);
    font-family: var(--font-body);
    font-size: 1em;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: 0.25px;
    padding: 0.5em 0.6875em;
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .navbar__link:hover {
    color: var(--color-primary);
  }

  .navbar__actions {
    display: flex;
    align-items: center;
    gap: 1em;
    animation: nav-slide-left 1s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both;
  }

  .navbar__menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5em;
    z-index: 100;
    position: relative;
  }

  .navbar__burger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 24px;
    height: 24px;
  }

  @keyframes burger-top {
    from { transform: translateY(0) rotate(0deg); }
    to { transform: translateY(7px) rotate(45deg); }
  }

  @keyframes burger-top-reverse {
    from { transform: translateY(7px) rotate(45deg); }
    to { transform: translateY(0) rotate(0deg); }
  }

  @keyframes burger-mid {
    from { opacity: 1; }
    to { opacity: 0; }
  }

  @keyframes burger-mid-reverse {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes burger-bottom {
    from { transform: translateY(0) rotate(0deg); }
    to { transform: translateY(-7px) rotate(-45deg); }
  }

  @keyframes burger-bottom-reverse {
    from { transform: translateY(-7px) rotate(-45deg); }
    to { transform: translateY(0) rotate(0deg); }
  }

  .navbar__burger-line {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-primary);
    border-radius: 2px;
    transform-origin: center;
  }

  .navbar__menu-toggle.is-open .navbar__burger-line:nth-child(1) {
    animation: burger-top 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .navbar__menu-toggle.is-open .navbar__burger-line:nth-child(2) {
    animation: burger-mid 0.2s ease forwards;
  }

  .navbar__menu-toggle.is-open .navbar__burger-line:nth-child(3) {
    animation: burger-bottom 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .navbar__menu-toggle.is-closing .navbar__burger-line:nth-child(1) {
    animation: burger-top-reverse 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .navbar__menu-toggle.is-closing .navbar__burger-line:nth-child(2) {
    animation: burger-mid-reverse 0.2s ease forwards;
  }

  .navbar__menu-toggle.is-closing .navbar__burger-line:nth-child(3) {
    animation: burger-bottom-reverse 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .navbar__mobile-menu {
    display: none;
  }

  @media (max-width: 991px) {
    .navbar__links {
      display: none;
    }

    .navbar__inner {
      z-index: 100;
    }

    .navbar__menu-toggle {
      display: flex;
    }

    .navbar__actions {
      animation: none;
    }

    .navbar__actions :global(.btn-expand) {
      display: none;
    }

    .navbar__mobile-menu {
      display: flex;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100vh;
      height: 100dvh;
      z-index: 99;
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      transform: translateX(-100%);
      transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .navbar__mobile-menu.is-open {
      transform: translateX(0);
    }

    .navbar__mobile-inner {
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-bottom: 10vh;
    }

    .navbar__mobile-links {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0;
      width: 100%;
      padding: 0 3em;
    }

    .navbar__mobile-link {
      font-family: var(--font-body);
      font-size: 2.5em;
      font-weight: 500;
      color: var(--color-primary);
      text-decoration: none;
      padding: 0.35em 0;
      opacity: 0;
      transform: translateY(1.5em);
      transition: opacity 0.4s ease, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), color 0.2s ease;
    }

    .navbar__mobile-link:hover {
      color: var(--color-primary);
    }

    .navbar__mobile-menu.is-open .navbar__mobile-link {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 767px) {
    .navbar__mobile-link {
      font-size: 2em;
    }

    .navbar__mobile-links {
      padding: 0 2em;
    }

    .navbar__mobile-inner {
      padding-bottom: 8vh;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .navbar__links,
    .navbar__actions {
      animation: none;
    }
  }
</style>
