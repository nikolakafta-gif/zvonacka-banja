---
import "../styles/global.css";
import "../styles/tailwind.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  schema?: Record<string, unknown>;
  extraSchemas?: Record<string, unknown>[];
}

const {
  title = "Nikola Miljković | AI-Powered Web Developer",
  description = "I build pixel-perfect websites powered by AI, one project at a time. Thoughtful structure, clean interactions, and modern execution.",
  ogImage = "/og-image.jpg",
  schema,
  extraSchemas = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

const defaultSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Nikola Miljković",
  "description": description,
  "url": canonicalURL.href,
  "image": ogImageURL.href,
  "founder": {
    "@type": "Person",
    "name": "Nikola Miljković",
    "jobTitle": "AI-Powered Web Developer",
    "url": "https://www.nikolamiljkovic.live",
    "knowsAbout": ["Web Development", "Webflow", "Astro", "UI/UX Design", "AI-Enhanced Workflows", "Landing Pages", "JavaScript", "CSS"],
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Nis",
      "addressCountry": "RS"
    },
    "sameAs": [
      "https://www.linkedin.com/in/nikola-miljkovic-542456108/",
      "https://www.instagram.com/nidza____/",
      "https://dribbble.com/nikola-miljkovic",
      "https://www.behance.net/nikolamiljkovic5"
    ]
  },
  "areaServed": {
    "@type": "GeoCircle",
    "geoMidpoint": {
      "@type": "GeoCoordinates",
      "latitude": 43.3209,
      "longitude": 21.8954
    },
    "description": "Worldwide (remote)"
  },
  "serviceType": ["Web Development", "Website Redesign", "Landing Page Design", "Webflow Development"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Nis",
    "addressCountry": "RS"
  },
  "sameAs": [
    "https://www.linkedin.com/in/nikola-miljkovic-542456108/",
    "https://www.instagram.com/nidza____/",
    "https://dribbble.com/nikola-miljkovic",
    "https://www.behance.net/nikolamiljkovic5"
  ]
};

const pageSchema = schema || defaultSchema;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL.href} />

    <meta name="theme-color" content="#4928fd" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Nikola Miljković" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter+Tight:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-9HHYCK1DJM"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-9HHYCK1DJM');
    </script>

    <!-- JSON-LD Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
    {extraSchemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <slot />

    <script>
      import Lenis from "lenis";

      /* Prevent browser scroll restoration fighting with Lenis on refresh */
      if ("scrollRestoration" in history) {
        history.scrollRestoration = "manual";
      }
      window.scrollTo(0, 0);

      function initLenis() {
        const lenis = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          touchMultiplier: 2,
        });

        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }

        requestAnimationFrame(raf);

        /* Handle anchor links smoothly */
        document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
          anchor.addEventListener("click", (e) => {
            const href = (anchor as HTMLAnchorElement).getAttribute("href");
            if (!href || href === "#") return;
            const target = document.querySelector(href);
            if (target) {
              e.preventDefault();
              lenis.scrollTo(target as HTMLElement, { offset: -80 });
            }
          });
        });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initLenis);
      } else {
        initLenis();
      }
      document.addEventListener("astro:page-load", initLenis);
    </script>

    <script>
      import { initScrollAnimations } from "../scripts/scroll-animations";

      function boot() { initScrollAnimations(); }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", boot);
      } else {
        boot();
      }
      document.addEventListener("astro:page-load", boot);
    </script>
  </body>
</html>
