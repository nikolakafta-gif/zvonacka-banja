---
const testimonials = [
  {
    quote: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua ut enim ad minim veniam.",
    name: "Sarah Mitchell",
    role: "Wellness Enthusiast",
  },
  {
    quote: "Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit.",
    name: "James Whitmore",
    role: "Holistic Health Advocate",
  },
  {
    quote: "Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur excepteur sint occaecat cupidatat non proident.",
    name: "Elena Rodriguez",
    role: "Returning Client",
  },
];
---

<section class="testimonials" id="testimonials">
  <div class="testimonials__inner container">
    <div class="testimonials__header">
      <span class="eyebrow">Kind Words</span>
      <h2 class="testimonials__heading">What Our<br>Clients Say</h2>
    </div>
    <div class="testimonials__grid">
      {testimonials.map((t) => (
        <blockquote class="testimonials__card">
          <p class="testimonials__quote">&ldquo;{t.quote}&rdquo;</p>
          <footer class="testimonials__author">
            <cite class="testimonials__name">{t.name}</cite>
            <span class="testimonials__role">{t.role}</span>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    width: 100%;
    background-color: var(--color-bg);
    padding-block: var(--spacing-section);
  }

  .testimonials__inner {
    display: flex;
    flex-direction: column;
    gap: 4em;
  }

  .testimonials__header {
    display: flex;
    flex-direction: column;
    gap: 1em;
    text-align: center;
    align-items: center;
  }

  .testimonials__heading {
    font-size: var(--text-h2);
    line-height: 1.08;
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5em;
  }

  .testimonials__card {
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 2.5em 2em;
    display: flex;
    flex-direction: column;
    gap: 2em;
    justify-content: space-between;
  }

  .testimonials__quote {
    font-family: var(--font-heading);
    font-size: 1.125em;
    font-weight: 400;
    font-style: italic;
    color: var(--color-heading);
    line-height: 1.6;
    letter-spacing: 0;
    text-transform: none;
  }

  .testimonials__author {
    display: flex;
    flex-direction: column;
    gap: 0.25em;
  }

  .testimonials__name {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 500;
    font-style: normal;
    color: var(--color-heading);
    letter-spacing: var(--tracking-ui);
    text-transform: uppercase;
  }

  .testimonials__role {
    font-size: 0.6875em;
    color: var(--color-muted);
  }

  @media (max-width: 991px) {
    .testimonials__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .testimonials__heading {
      font-size: 2.25em;
    }
  }

  @media (max-width: 767px) {
    .testimonials__grid {
      grid-template-columns: 1fr;
    }

    .testimonials__heading {
      font-size: 2em;
    }
  }
</style>
