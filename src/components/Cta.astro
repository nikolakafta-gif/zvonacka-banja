<section class="cta" id="contact">
  <div class="cta__inner container">
    <div class="cta__content">
      <span class="eyebrow">Begin Your Journey</span>
      <h2 class="cta__heading">Ready to Embrace<br>Natural Healing?</h2>
      <p class="cta__text">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Schedule your consultation today.
      </p>
      <div class="cta__buttons">
        <a href="#" class="btn">Book a Consult</a>
        <a href="#services" class="btn btn--outline">Explore Remedies</a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    width: 100%;
    background-color: var(--color-bg);
    padding-block: var(--spacing-section);
    border-top: 1px solid var(--color-border);
  }

  .cta__inner {
    display: flex;
    justify-content: center;
  }

  .cta__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5em;
    max-width: 36em;
  }

  .cta__heading {
    font-size: var(--text-h2);
    line-height: 1.08;
  }

  .cta__text {
    font-size: var(--text-body);
    color: var(--color-text);
    line-height: 1.8;
  }

  .cta__buttons {
    display: flex;
    gap: 1em;
    margin-top: 0.5em;
  }

  @media (max-width: 767px) {
    .cta__heading {
      font-size: 2em;
    }

    .cta__buttons {
      flex-direction: column;
      width: 100%;
    }

    .cta__buttons .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
