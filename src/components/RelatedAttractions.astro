---
interface Props {
  current: string;
}

const { current } = Astro.props;

const all = [
  {
    title: "Manastir Poganovo",
    description: "Srednjovekovni manastir iz 14. veka u kanjonu reke Jerme",
    image: "/assets/images/card-manastir-poganovo.jpg",
    alt: "Manastir Poganovo u kanjonu reke Jerme",
    href: "/manastir-poganovo/",
  },
  {
    title: "Kanjon reke Jerme",
    description: "Živopisna klisura netaknute prirode idealna za šetnje i izlete",
    image: "/assets/images/card-kanjon-jerme.jpg",
    alt: "Kanjon reke Jerme sa visokim liticama",
    href: "/kanjon-jerme/",
  },
  {
    title: "Bazen Zvonačka Banja",
    description: "Olimpijski bazeni sa termomineralnom vodom temperature 28°C",
    image: "/assets/images/card-bazen-zvonacka-banja.jpg",
    alt: "Otvoreni olimpijski bazen sa mineralnom vodom",
    href: "/bazen-zvonacka-banja/",
  },
  {
    title: "Asenovo Kale",
    description: "Greben na 1032 m — gnezda surih orlova i pećina Vetrena Dupka",
    image: "/assets/images/card-asenovo-kale.jpg",
    alt: "Asenovo Kale sa panoramskim pogledom",
    href: "/asenovo-kale/",
  },
  {
    title: "Vodič za Zvonačku Banju",
    description: "Kompletni vodič — kako doći, šta leči, bazeni, atrakcije i smeštaj",
    image: "/assets/images/hero-services.jpg",
    alt: "Zvonačka Banja — vodič za posetioce",
    href: "/vodic/",
  },
];

const related = all.filter((item) => item.href !== current);
---

<section class="related">
  <div class="related__inner container">
    <h2 class="related__heading">Istražite još</h2>
    <div class="related__grid">
      {related.map((item) => (
        <a href={item.href} class="related__card">
          <div class="related__card-image">
            <img src={item.image} alt={item.alt} width="400" height="267" loading="lazy" />
          </div>
          <h3 class="related__card-title">{item.title}</h3>
          <p class="related__card-text">{item.description}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .related {
    width: 100%;
    background-color: var(--color-bg-dark, #1F2C22);
    padding-block: 4em;
  }

  .related__inner {
    max-width: var(--size-container);
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .related__heading {
    font-family: var(--font-heading);
    font-size: var(--text-h3);
    font-weight: 400;
    color: var(--color-heading);
    margin-bottom: 2em;
  }

  .related__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2em;
  }

  .related__card {
    display: flex;
    flex-direction: column;
    gap: 0.75em;
    text-decoration: none;
    color: inherit;
    transition: opacity var(--transition-base);
  }

  .related__card:hover {
    opacity: 0.85;
  }

  .related__card-image {
    border-radius: 0.5em;
    overflow: hidden;
    aspect-ratio: 3 / 2;
  }

  .related__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .related__card-title {
    font-family: var(--font-heading);
    font-size: var(--text-h4, 1.25em);
    font-weight: 400;
    color: var(--color-heading);
  }

  .related__card-text {
    font-size: var(--text-small);
    color: var(--color-text-light);
    line-height: 1.6;
    font-weight: 300;
  }

  @media (max-width: 991px) {
    .related__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .related__grid {
      grid-template-columns: 1fr;
      gap: 1.5em;
    }
  }
</style>
