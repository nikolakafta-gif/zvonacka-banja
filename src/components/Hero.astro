---
---

<section class="hero">
  <div class="hero__bg">
    <div class="hero__overlay"></div>
  </div>
  <div class="hero__inner container">
    <span class="eyebrow">Natural Healing & Herbal Remedies</span>
    <h1 class="hero__title">The Herbal<br>Alchemist</h1>
    <p class="hero__subtitle">Handcrafted remedies rooted in tradition, guided by nature.</p>
    <a href="#contact" class="btn hero__btn">Book a Consult</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 5em;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background-color: #2a3a2d;
    background-image: url('/assets/images/hero-bg.jpg');
    background-size: cover;
    background-position: center;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(31, 44, 34, 0.4) 0%,
      rgba(31, 44, 34, 0.7) 100%
    );
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5em;
    padding-block: 6em;
  }

  .hero__title {
    font-size: var(--text-h1);
    line-height: 1.0;
  }

  .hero__subtitle {
    font-size: var(--text-body);
    color: var(--color-text);
    max-width: 28em;
    line-height: 1.8;
  }

  .hero__btn {
    margin-top: 0.5em;
  }

  @media (max-width: 991px) {
    .hero__title {
      font-size: 3em;
    }
  }

  @media (max-width: 767px) {
    .hero {
      min-height: 85vh;
    }

    .hero__title {
      font-size: 2.5em;
    }

    .hero__inner {
      padding-block: 4em;
    }
  }

  @media (max-width: 479px) {
    .hero__title {
      font-size: 2em;
    }
  }
</style>
