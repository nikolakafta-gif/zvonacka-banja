---
---

<section class="hero">
  <div class="hero__bg">
    <div class="hero__overlay"></div>
  </div>
  <div class="hero__inner container">
    <span class="eyebrow">Lekovita vazdušna banja</span>
    <h1 class="hero__title">Zvonačka<br><span class="hero__title-accent">Banja</span></h1>
    <p class="hero__subtitle">Lekovita banja na 670 m nadmorske visine, u dolini reke Jerme. Termomineralna voda, čist vazduh i netaknuta priroda jugoistočne Srbije.</p>
    <a href="https://www.trivago.rs/sr/odr/hotel-a-zvona%C4%8Dka-banja-srbija?search=200-418352" target="_blank" rel="noopener noreferrer" class="btn hero__btn">Pogledaj smeštaj</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    max-width: 2440px;
    margin-inline: auto;
    min-height: 100vh;
    display: flex;
    align-items: flex-end;
    padding-top: 5em;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background-color: #2a3a2d;
    background-image: url('/assets/images/hero-bazeni-2.jpg');
    background-size: cover;
    background-position: center;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(31, 44, 34, 0.4) 0%,
      rgba(31, 44, 34, 0.7) 100%
    );
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5em;
    padding-block: 6em;
  }

  .hero__title {
    font-size: var(--text-h1);
    line-height: 1.0;
  }

  .hero__subtitle {
    font-size: var(--text-body);
    color: var(--color-text-light);
    max-width: 28em;
    line-height: 1.8;
  }

  .hero__title-accent {
    font-style: normal;
  }

  .hero__btn {
    margin-top: 0.5em;
  }

  @media (max-width: 991px) {
    .hero {
      min-height: 70vh;
    }

    .hero__title {
      font-size: 3em;
    }
  }

  @media (max-width: 767px) {
    .hero {
      min-height: 70vh;
    }

    .hero__title {
      font-size: 2.5em;
    }

    .hero__inner {
      padding-block: 3em;
    }
  }

  @media (max-width: 479px) {
    .hero__title {
      font-size: 2em;
    }
  }
</style>
