---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__top" data-fade-up>
      <div class="footer__brand">
        <a href="/" class="footer__logo">Zvonačka Banja</a>
        <p class="footer__tagline">
          Lekovita vazdušna banja u jugoistočnoj Srbiji, na obroncima Vlaške planine. Termomineralna voda, čist vazduh i netaknuta priroda.
        </p>
      </div>
      <nav class="footer__nav" aria-label="Footer navigation">
        <div class="footer__col">
          <h3 class="footer__col-title">Navigacija</h3>
          <ul class="footer__list">
            <li><a href="/#home" class="footer__link">Početna</a></li>
            <li><a href="/#about" class="footer__link">O Banji</a></li>
            <li><a href="/#services" class="footer__link">Šta Posetiti</a></li>
            <li><a href="/#testimonials" class="footer__link">Utisci</a></li>
          </ul>
        </div>
        <div class="footer__col">
          <h3 class="footer__col-title">Sadržaj</h3>
          <ul class="footer__list">
            <li><a href="/#contact" class="footer__link">Bazenski kompleks</a></li>
            <li><a href="https://www.trivago.rs/sr/odr/hotel-a-zvona%C4%8Dka-banja-srbija?search=200-418352" target="_blank" rel="noopener noreferrer" class="footer__link">Smeštaj</a></li>
          </ul>
        </div>
        <div class="footer__col">
          <h3 class="footer__col-title">Kontakt</h3>
          <ul class="footer__list">
            <li><a href="https://maps.google.com/?q=Zvonačka+Banja" target="_blank" rel="noopener noreferrer" class="footer__link">Zvonačka Banja, Srbija</a></li>
          </ul>
        </div>
      </nav>
    </div>
    <div class="footer__bottom">
      <p class="footer__copy">&copy; {currentYear} Zvonačka Banja. Sva prava zadržana.</p>
      <a href="https://www.nikolamiljkovic.live" target="_blank" rel="noopener noreferrer" class="footer__credit">
        Sajt izradio
        <span class="footer__credit-name">
          Nikola Miljković
          <svg class="footer__credit-underline" viewBox="0 0 300 20" preserveAspectRatio="none">
            <path d="M 0,10 Q 75,0 150,10 Q 225,20 300,10" stroke="currentColor" stroke-width="2" fill="none" />
          </svg>
        </span>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    width: 100%;
    background-color: var(--color-bg-deep);
    border-top: 1px solid var(--color-border);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4em;
    padding-block: 4em;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 1em;
  }

  .footer__logo {
    font-family: var(--font-heading);
    font-size: 1.5em;
    font-weight: 500;
    color: var(--color-heading);
    letter-spacing: var(--tracking-display);
    text-transform: uppercase;
  }

  .footer__tagline {
    font-size: 0.8125em;
    color: var(--color-muted);
    line-height: 1.7;
    max-width: 20em;
  }

  .footer__nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2em;
  }

  .footer__col-title {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-heading);
    letter-spacing: var(--tracking-ui);
    text-transform: uppercase;
    margin-bottom: 1.25em;
  }

  .footer__list {
    display: flex;
    flex-direction: column;
    gap: 0.75em;
  }

  .footer__link {
    font-size: 0.8125em;
    color: var(--color-muted);
    transition: color var(--transition-base);
  }

  .footer__link:hover {
    color: var(--color-heading);
  }

  .footer__bottom {
    border-top: 1px solid var(--color-border);
    padding-block: 2em;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1em;
  }

  .footer__copy {
    font-size: 0.6875em;
    color: var(--color-muted);
  }

  .footer__credit {
    font-size: 0.875em;
    color: var(--color-muted);
    transition: color var(--transition-base);
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
  }

  .footer__credit:hover {
    color: var(--color-heading);
  }

  .footer__credit-name {
    position: relative;
    font-weight: 500;
    color: var(--color-text-light);
    transition: color var(--transition-base);
    animation: credit-glow 3s ease-in-out infinite;
  }

  @keyframes credit-glow {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  .footer__credit:hover .footer__credit-name {
    color: var(--color-heading);
    animation: none;
    opacity: 1;
  }

  .footer__credit-underline {
    position: absolute;
    bottom: -0.3em;
    left: 0;
    width: 100%;
    height: 0.5em;
    color: var(--color-heading);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .footer__credit-underline path {
    stroke-dasharray: 500;
    stroke-dashoffset: 500;
    transition: stroke-dashoffset 0s;
  }

  .footer__credit:hover .footer__credit-underline {
    opacity: 1;
  }

  .footer__credit:hover .footer__credit-underline path {
    stroke-dashoffset: 0;
    transition: stroke-dashoffset 0.8s ease-in-out;
  }

  @media (max-width: 991px) {
    .footer__top {
      grid-template-columns: 1fr;
      gap: 3em;
    }
  }

  @media (max-width: 767px) {
    .footer__nav {
      grid-template-columns: 1fr 1fr;
    }

    .footer__bottom {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.75em;
    }
  }

  @media (max-width: 479px) {
    .footer__nav {
      grid-template-columns: 1fr;
    }
  }
</style>
