---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import RelatedAttractions from "../components/RelatedAttractions.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Kanjon reke Jerme | Prirodni dragulj kod Zvonačke Banje"
  description="Živopisna klisura reke Jerme sa stenovitim liticama i bistrom vodom. Idealna za pešačenje, fotografiju i izlete u netaknutoj prirodi jugoistočne Srbije."
  schema={{
    "@context": "https://schema.org",
    "@type": "TouristAttraction",
    "name": "Kanjon reke Jerme",
    "description": "Živopisna klisura reke Jerme u neposrednoj blizini Zvonačke Banje. Netaknuta priroda idealna za šetnje, izlete i fotografiju.",
    "url": "https://www.zvonackabanja.net/kanjon-jerme/",
    "image": "https://www.zvonackabanja.net/assets/images/card-kanjon-jerme.jpg",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Zvonačka Banja",
      "addressRegion": "Pirotski okrug",
      "addressCountry": "RS"
    },
    "isPartOf": {
      "@type": "TouristAttraction",
      "name": "Zvonačka Banja",
      "url": "https://www.zvonackabanja.net/"
    }
  }}
  extraSchemas={[
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Početna", "item": "https://www.zvonackabanja.net/" },
        { "@type": "ListItem", "position": 2, "name": "Šta Posetiti", "item": "https://www.zvonackabanja.net/#services" },
        { "@type": "ListItem", "position": 3, "name": "Kanjon reke Jerme", "item": "https://www.zvonackabanja.net/kanjon-jerme/" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Gde se nalazi kanjon reke Jerme?",
          "acceptedAnswer": { "@type": "Answer", "text": "Kanjon reke Jerme se nalazi u jugoistočnoj Srbiji, u Pirotskom okrugu, u neposrednoj blizini Zvonačke Banje. Proteže se duž toka reke Jerme koja izvire u Bugarskoj i uliva se u Nišavu." }
        },
        {
          "@type": "Question",
          "name": "Kako doći do kanjona reke Jerme?",
          "acceptedAnswer": { "@type": "Answer", "text": "Do kanjona se dolazi regionalnim putevima iz pravca Pirota (oko 30 km) ili Babušnice. Put prolazi direktno kroz kanjon, pružajući spektakularne poglede na stenovite litice i bistru reku." }
        },
        {
          "@type": "Question",
          "name": "Koje aktivnosti su moguće u kanjonu Jerme?",
          "acceptedAnswer": { "@type": "Answer", "text": "Kanjon nudi pešačenje i planinarenje stazama uz reku, fotografiju prirode, ribolov, posmatranje ptica (uključujući suri orao), i posetе obližnjim manastirima. U blizini su i bazeni sa termomineralnom vodom." }
        },
        {
          "@type": "Question",
          "name": "Da li je kanjon Jerme pogodan za jednodnevni izlet?",
          "acceptedAnswer": { "@type": "Answer", "text": "Da, kanjon je idealan za jednodnevni izlet iz Pirota ili Niša. Kombinujte posetu kanjonu sa kupanjem u bazenima Zvonačke Banje, obilaskom manastira Poganovo i penjanjem na Asenovo Kale." }
        },
        {
          "@type": "Question",
          "name": "Koliko je dugačak kanjon reke Jerme?",
          "acceptedAnswer": { "@type": "Answer", "text": "Kanjon reke Jerme se proteže na dužini od oko 20 km kroz jugoistočnu Srbiju. Najimpresivniji deo kanjona sa visokim stenovitim liticama nalazi se u blizini Zvonačke Banje i manastira Poganovo." }
        },
        {
          "@type": "Question",
          "name": "Šta mogu videti u kanjonu Jerme?",
          "acceptedAnswer": { "@type": "Answer", "text": "U kanjonu možete videti visoke stenovite litice, bistru reku sa malim slapovima, bogatu vegetaciju, razne vrste ptica uključujući surog orla, i jedinstven pogled na netaknutu prirodu jugoistočne Srbije." }
        },
        {
          "@type": "Question",
          "name": "Da li postoje staze za pešačenje uz kanjon?",
          "acceptedAnswer": { "@type": "Answer", "text": "Da, uz kanjon reke Jerme postoje staze za pešačenje različitih težina. Staze vode kroz spektakularne predele i pružaju nezaboravne poglede na vertikalne litice i gustu vegetaciju. Postoje i staze zdravlja u sklopu Zvonačke Banje." }
        },
        {
          "@type": "Question",
          "name": "Koje znamenitosti su u blizini kanjona?",
          "acceptedAnswer": { "@type": "Answer", "text": "U blizini se nalaze bazeni Zvonačke Banje sa termomineralnom vodom (28°C), manastir Poganovo iz 14. veka, greben Asenovo Kale (1032 m) sa gnezdima surih orlova, i pećina Vetrena Dupka sa 4 km kanala." }
        }
      ]
    }
  ]}
>
  <Navbar />
  <main id="main-content">
    <section class="attraction-hero">
      <div class="attraction-hero__bg">
        <div class="attraction-hero__overlay"></div>
      </div>
      <div class="attraction-hero__inner container">
        <a href="/#services" class="attraction-hero__back">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
          Nazad
        </a>
        <span class="eyebrow">Šta Posetiti</span>
        <h1 class="attraction-hero__title">Kanjon reke<br><span class="attraction-hero__accent">Jerme</span></h1>
      </div>
    </section>

    <section class="attraction-content">
      <div class="attraction-content__inner container">
        <div class="attraction-content__text" data-fade-up>
          <p>
            Kanjon reke Jerme je živopisna klisura u jugoistočnoj Srbiji koja se proteže na dužini od oko 20 km kroz Pirotski okrug. Sa visokim stenovitim liticama, bistrom vodom i netaknutom prirodom, kanjon je idealan za pešačenje, fotografiju i jednodnevne izlete. Nalazi se u neposrednoj blizini Zvonačke Banje.
          </p>
        </div>
        <div class="attraction-content__image" data-reveal>
          <img src="/assets/images/kanjon-jerme-content.jpg" alt="Kanjon reke Jerme sa visokim liticama" width="1200" height="800" loading="lazy" />
          <div class="attraction-content__image-overlay"></div>
        </div>
      </div>
    </section>

    <section class="attraction-details">
      <div class="attraction-details__inner container">
        <h2>Kako izgleda kanjon reke Jerme?</h2>
        <p>
          Kanjon reke Jerme je poznat po visokim stenovitim liticama koje se uzdižu iznad bistrog rečnog toka. Vertikalne stene su obrasle gustom vegetacijom, a reka meandrira kroz uske prolaze stvarajući spektakularne predele. Sam put kroz kanjon, bilo kolima ili pešice, pruža nezaboravne poglede na ovu netaknutu prirodu jugoistočne Srbije.
        </p>

        <h2>Koje aktivnosti su moguće u kanjonu?</h2>
        <p>
          Kanjon nudi raznovrsne aktivnosti za ljubitelje prirode. Staze za pešačenje uz reku vode kroz spektakularne predele, od laganih šetnji pogodnih za porodice do zahtevnijih planinarskih ruta. Kanjon je idealan za fotografiju prirode, posmatranje ptica (uključujući surog orla), i ribolov. U blizini su i staze za planinarenje po Vlaškoj i Staroj planini.
        </p>

        <h2>Kako doći do kanjona reke Jerme?</h2>
        <p>
          Do kanjona se dolazi regionalnim putevima iz pravca Pirota (udaljenost oko 30 km) ili Babušnice, dolinom reke Jerme. Put prolazi direktno kroz kanjon, pružajući spektakularne poglede na stenovite litice i bistru reku. Kanjon je pristupačan automobilom, a za pešačenje su dostupne obeležene staze.
        </p>

        <h2>Da li je kanjon pogodan za jednodnevni izlet?</h2>
        <p>
          Da, kanjon Jerme je idealan za jednodnevni izlet iz Pirota, Niša ili čak Beograda. Preporučeni plan za jedan dan: vožnja kroz kanjon, kupanje u <a href="/bazen-zvonacka-banja/">bazenima Zvonačke Banje</a> sa termomineralnom vodom, obilazak <a href="/manastir-poganovo/">manastira Poganovo</a>, i penjanje na <a href="/asenovo-kale/">Asenovo Kale</a> za panoramski pogled.
        </p>

        <h2>Šta još posetiti u okolini kanjona?</h2>
        <p>
          U neposrednoj blizini kanjona nalaze se bazeni Zvonačke Banje sa termomineralnom vodom temperature 28°C, manastir Poganovo iz 14. veka sa izuzetnim freskama, greben Asenovo Kale na 1032 m nadmorske visine (jedino mesto u Srbiji sa gnezdima surih orlova), i pećina Vetrena Dupka sa 4 km podzemnih kanala. Obližnji manastiri Sukovo i Temska dopunjuju kulturno-istorijsku ponudu.
        </p>
      </div>
    </section>

    <section class="attraction-faq">
      <div class="attraction-faq__inner container">
        <h2>Često postavljana pitanja o kanjonu reke Jerme</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>Gde se nalazi kanjon reke Jerme?</summary>
            <div class="faq-item__answer">
              <p>Kanjon reke Jerme se nalazi u jugoistočnoj Srbiji, u Pirotskom okrugu, u neposrednoj blizini Zvonačke Banje. Proteže se duž toka reke Jerme koja izvire u Bugarskoj i uliva se u Nišavu.</p>
            </div>
          </details>
          <details class="faq-item">
            <summary>Kako doći do kanjona reke Jerme?</summary>
            <div class="faq-item__answer">
              <p>Do kanjona se dolazi regionalnim putevima iz pravca Pirota (oko 30 km) ili Babušnice. Put prolazi direktno kroz kanjon, pružajući spektakularne poglede na stenovite litice i bistru reku.</p>
            </div>
          </details>
          <details class="faq-item">
            <summary>Koje aktivnosti su moguće u kanjonu Jerme?</summary>
            <div class="faq-item__answer">
              <p>Kanjon nudi pešačenje i planinarenje stazama uz reku, fotografiju prirode, ribolov, posmatranje ptica (uključujući suri orao), i posete obližnjim manastirima. U blizini su i bazeni sa termomineralnom vodom.</p>
            </div>
          </details>
          <details class="faq-item">
            <summary>Da li je kanjon Jerme pogodan za jednodnevni izlet?</summary>
            <div class="faq-item__answer">
              <p>Da, kanjon je idealan za jednodnevni izlet iz Pirota ili Niša. Kombinujte posetu kanjonu sa kupanjem u bazenima Zvonačke Banje, obilaskom manastira Poganovo i penjanjem na Asenovo Kale.</p>
            </div>
          </details>
          <details class="faq-item">
            <summary>Koliko je dugačak kanjon reke Jerme?</summary>
            <div class="faq-item__answer">
              <p>Kanjon reke Jerme se proteže na dužini od oko 20 km kroz jugoistočnu Srbiju. Najimpresivniji deo kanjona sa visokim stenovitim liticama nalazi se u blizini Zvonačke Banje i manastira Poganovo.</p>
            </div>
          </details>
          <details class="faq-item">
            <summary>Šta mogu videti u kanjonu Jerme?</summary>
            <div class="faq-item__answer">
              <p>U kanjonu možete videti visoke stenovite litice, bistru reku sa malim slapovima, bogatu vegetaciju, razne vrste ptica uključujući surog orla, i jedinstven pogled na netaknutu prirodu jugoistočne Srbije.</p>
            </div>
          </details>
          <details class="faq-item">
            <summary>Da li postoje staze za pešačenje uz kanjon?</summary>
            <div class="faq-item__answer">
              <p>Da, uz kanjon reke Jerme postoje staze za pešačenje različitih težina. Staze vode kroz spektakularne predele i pružaju nezaboravne poglede na vertikalne litice i gustu vegetaciju. Postoje i staze zdravlja u sklopu Zvonačke Banje.</p>
            </div>
          </details>
          <details class="faq-item">
            <summary>Koje znamenitosti su u blizini kanjona?</summary>
            <div class="faq-item__answer">
              <p>U blizini se nalaze bazeni Zvonačke Banje sa termomineralnom vodom (28°C), manastir Poganovo iz 14. veka, greben Asenovo Kale (1032 m) sa gnezdima surih orlova, i pećina Vetrena Dupka sa 4 km kanala.</p>
            </div>
          </details>
        </div>
      </div>
    </section>

    <RelatedAttractions current="/kanjon-jerme/" />
  </main>
  <Footer />
</BaseLayout>

<style>
  .attraction-hero {
    position: relative;
    width: 100%;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    padding-top: 5em;
    overflow: hidden;
  }

  .attraction-hero__bg {
    position: absolute;
    inset: 0;
    background-color: #2a3a2d;
    background-image: url('/assets/images/card-kanjon-jerme.jpg');
    background-size: cover;
    background-position: center;
  }

  .attraction-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(31,44,34,0.3) 0%, rgba(31,44,34,0.8) 100%);
  }

  .attraction-hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25em;
    padding-block: 4em;
  }

  .attraction-hero__back {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: var(--tracking-ui);
    transition: color var(--transition-base);
  }

  .attraction-hero__back:hover {
    color: var(--color-heading);
  }

  .attraction-hero__title {
    font-size: var(--text-h1);
    line-height: 1.0;
  }

  .attraction-hero__accent {
    font-style: italic;
  }

  .attraction-content {
    width: 100%;
    background-color: var(--color-bg);
    padding-block: var(--spacing-section);
  }

  .attraction-content__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5em;
  }

  .attraction-content__text {
    max-width: 48em;
    text-align: center;
  }

  .attraction-content__text p {
    font-size: var(--text-body);
    color: var(--color-text-light);
    line-height: 1.8;
    font-weight: 300;
  }

  .attraction-content__image {
    position: relative;
    width: 100%;
    max-width: 52em;
    margin-inline: auto;
    border-radius: 0.75em;
    overflow: hidden;
    aspect-ratio: 16/9;
  }

  .attraction-content__image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .attraction-content__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(31, 44, 34, 0.15) 0%, rgba(31, 44, 34, 0.4) 100%);
    pointer-events: none;
  }

  @media (max-width: 991px) {
    .attraction-hero__title {
      font-size: 3em;
    }
  }

  @media (max-width: 767px) {
    .attraction-hero {
      min-height: 60vh;
    }

    .attraction-hero__title {
      font-size: 2.5em;
    }
  }

  .attraction-details {
    width: 100%;
    background-color: var(--color-bg);
    padding-block: 0 var(--spacing-section);
  }

  .attraction-details__inner {
    max-width: 48em;
    margin-inline: auto;
  }

  .attraction-details__inner h2 {
    font-size: var(--text-h2);
    color: var(--color-heading);
    margin-top: 2.5em;
    margin-bottom: 1em;
    font-weight: 400;
    line-height: 1.3;
  }

  .attraction-details__inner h2:first-child {
    margin-top: 0;
  }

  .attraction-details__inner p {
    font-size: var(--text-body);
    color: var(--color-text-light);
    line-height: 1.8;
    font-weight: 300;
  }

  .attraction-details__inner a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .attraction-faq {
    width: 100%;
    background-color: var(--color-bg-alt, #1a2a1d);
    padding-block: var(--spacing-section);
  }

  .attraction-faq__inner {
    max-width: 48em;
    margin-inline: auto;
  }

  .attraction-faq__inner > h2 {
    font-size: var(--text-h2);
    color: var(--color-heading);
    margin-bottom: 2em;
    font-weight: 500;
    line-height: 1.3;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
  }

  .faq-item {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .faq-item:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .faq-item summary {
    font-size: var(--text-body);
    color: var(--color-heading);
    font-weight: 500;
    padding: 1.25em 0;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1em;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: "+";
    font-size: 1.75em;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .faq-item[open] summary::after {
    content: "−";
  }

  .faq-item__answer {
    overflow: hidden;
  }

  .faq-item p {
    font-size: var(--text-body);
    color: var(--color-text-light);
    line-height: 1.8;
    font-weight: 300;
    padding-bottom: 1.25em;
  }

  @media (max-width: 479px) {
    .attraction-hero__title {
      font-size: 2em;
    }
  }
</style>
