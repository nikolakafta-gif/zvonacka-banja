---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import RelatedAttractions from "../components/RelatedAttractions.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Manastir Poganovo — Srednjovekovni manastir iz 14. veka | Zvonačka Banja"
  description="Manastir Poganovo je posvećen Svetom Jovanu Bogoslovu i poznat po izuzetnim freskama. Smešten u kanjonu reke Jerme, okružen liticama i netaknutom prirodom. U blizini manastiri Sukovo i Temska."
  schema={{
    "@context": "https://schema.org",
    "@type": "TouristAttraction",
    "name": "Manastir Poganovo",
    "description": "Srednjovekovni manastir Poganovo iz 14. veka, najpoznatiji od obližnjih manastira Zvonačke Banje. Posvećen Svetom Jovanu Bogoslovu, poznat po izuzetnim freskama.",
    "url": "https://www.zvonackabanja.net/manastir-poganovo/",
    "image": "https://www.zvonackabanja.net/assets/images/card-manastir-poganovo.jpg",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Zvonačka Banja",
      "addressRegion": "Pirotski okrug",
      "addressCountry": "RS"
    },
    "isPartOf": {
      "@type": "TouristAttraction",
      "name": "Zvonačka Banja",
      "url": "https://www.zvonackabanja.net/"
    }
  }}
  extraSchemas={[
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Početna", "item": "https://www.zvonackabanja.net/" },
        { "@type": "ListItem", "position": 2, "name": "Šta Posetiti", "item": "https://www.zvonackabanja.net/#services" },
        { "@type": "ListItem", "position": 3, "name": "Manastir Poganovo", "item": "https://www.zvonackabanja.net/manastir-poganovo/" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Kada je osnovan manastir Poganovo?",
          "acceptedAnswer": { "@type": "Answer", "text": "Manastir Poganovo je podignut u 14. veku. Prema predanju, osnivač manastira je srpski plemić iz dinastije Dragaša. Manastir je posvećen Svetom Jovanu Bogoslovu." }
        },
        {
          "@type": "Question",
          "name": "Čime je poznat manastir Poganovo?",
          "acceptedAnswer": { "@type": "Answer", "text": "Manastir Poganovo je poznat po izuzetnim freskama iz 14. i 15. veka koje svedoče o bogatoj umetničkoj tradiciji srednjovekovne Srbije. Posebno se ističe freska Sv. Jovana Bogoslova." }
        },
        {
          "@type": "Question",
          "name": "Gde se nalazi manastir Poganovo?",
          "acceptedAnswer": { "@type": "Answer", "text": "Manastir Poganovo se nalazi u kanjonu reke Jerme, u neposrednoj blizini Zvonačke Banje, u jugoistočnoj Srbiji (Pirotski okrug). Okružen je stenovitim liticama i gustom vegetacijom." }
        },
        {
          "@type": "Question",
          "name": "Kako doći do manastira Poganovo?",
          "acceptedAnswer": { "@type": "Answer", "text": "Do manastira se dolazi regionalnim putem iz pravca Pirota ili Babušnice, dolinom reke Jerme. Manastir je udaljen oko 30 km od Pirota. Put prolazi kroz spektakularan kanjon reke Jerme." }
        },
        {
          "@type": "Question",
          "name": "Koji još manastiri postoje u okolini Zvonačke Banje?",
          "acceptedAnswer": { "@type": "Answer", "text": "Pored manastira Poganovo, u okolini se nalaze manastiri Sukovo i Temska. Sva tri manastira zajedno čine dragoceno kulturno-istorijsko nasleđe jugoistočne Srbije." }
        },
        {
          "@type": "Question",
          "name": "Da li je manastir Poganovo otvoren za posetioce?",
          "acceptedAnswer": { "@type": "Answer", "text": "Da, manastir Poganovo je otvoren za posetioce tokom cele godine. Manastir je aktivan i u njemu žive monahinje. Posetioci mogu razgledati crkvu, freske i manastirski kompleks." }
        },
        {
          "@type": "Question",
          "name": "Šta još mogu posetiti u blizini manastira?",
          "acceptedAnswer": { "@type": "Answer", "text": "U blizini manastira nalaze se kanjon reke Jerme, bazeni Zvonačke Banje sa termomineralnom vodom, greben Asenovo Kale sa gnezdima surih orlova i pećina Vetrena Dupka sa 4 km podzemnih kanala." }
        },
        {
          "@type": "Question",
          "name": "Da li postoji parking kod manastira Poganovo?",
          "acceptedAnswer": { "@type": "Answer", "text": "Da, ispred manastira se nalazi parking za posetioce. Prostor je ograničen, pa se tokom praznika i vikenda preporučuje dolazak u ranijim jutarnjim satima." }
        }
      ]
    }
  ]}
>
  <Navbar />
  <main id="main-content">
    <section class="attraction-hero">
      <div class="attraction-hero__bg">
        <div class="attraction-hero__overlay"></div>
      </div>
      <div class="attraction-hero__inner container">
        <a href="/#services" class="attraction-hero__back">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
          Nazad
        </a>
        <span class="eyebrow">Šta Posetiti</span>
        <h1 class="attraction-hero__title">Manastir<br><span class="attraction-hero__accent">Poganovo</span></h1>
      </div>
    </section>

    <section class="attraction-content">
      <div class="attraction-content__inner container">
        <div class="attraction-content__text" data-fade-up>
          <p>
            Manastir Poganovo je srednjovekovni manastir iz 14. veka posvećen Svetom Jovanu Bogoslovu, poznat po izuzetnim freskama i smešten u živopisnom kanjonu reke Jerme kod Zvonačke Banje. Jedan je od najvažnijih kulturno-istorijskih spomenika jugoistočne Srbije i aktivno mesto duhovnog života.
          </p>
        </div>
        <div class="attraction-content__image" data-reveal>
          <img src="/assets/images/manastir-poganovo-content.jpg" alt="Manastir Poganovo u kanjonu reke Jerme" width="1200" height="800" loading="lazy" />
          <div class="attraction-content__image-overlay"></div>
        </div>
      </div>
    </section>

    <section class="attraction-details">
      <div class="attraction-details__inner container">
        <h2>Kada je osnovan i ko je izgradio manastir Poganovo?</h2>
        <p>
          Manastir Poganovo je podignut u 14. veku, u vreme vladavine srpskih despota. Prema predanju, osnivač manastira je srpski plemić iz dinastije Dragaša. Manastir je smešten u samom kanjonu reke Jerme, na mestu gde se litice uzdižu visoko iznad rečnog korita, što mu je pružalo prirodnu zaštitu tokom turbulentnih istorijskih perioda.
        </p>

        <h2>Čime su posebne freske manastira Poganovo?</h2>
        <p>
          Manastir Poganovo je poznat po izuzetnim freskama iz 14. i 15. veka koje svedoče o bogatoj umetničkoj tradiciji srednjovekovne Srbije. Posebno se ističe freska Svetog Jovana Bogoslova, zaštitnika manastira. Freske su rađene u stilu moravske škole i predstavljaju vredne primere srpskog srednjovekovnog slikarstva. Crkva je posvećena Svetom Jovanu Bogoslovu — jedinom apostolu koji je umro prirodnom smrću.
        </p>

        <h2>Kako doći do manastira Poganovo?</h2>
        <p>
          Do manastira se dolazi regionalnim putem iz pravca Pirota (udaljenost oko 30 km) ili iz pravca Babušnice, dolinom reke Jerme. Put prolazi kroz spektakularan kanjon sa visokim stenovitim liticama — sam put je doživljaj za sebe. Ispred manastira se nalazi parking za posetioce, ali je prostor ograničen, pa se tokom praznika preporučuje raniji dolazak.
        </p>

        <h2>Koji još manastiri postoje u okolini?</h2>
        <p>
          Pored manastira Poganovo, u okolini Zvonačke Banje nalaze se i manastiri Sukovo i Temska. Sva tri manastira zajedno čine dragoceno kulturno-istorijsko nasleđe jugoistočne Srbije. Manastir Sukovo se nalazi uzvodno uz Jermu, dok je manastir Temska smešten u obližnjoj dolini reke Temštice. Poseta sva tri manastira je moguća u jednom danu.
        </p>

        <h2>Šta još posetiti u blizini manastira?</h2>
        <p>
          U neposrednoj blizini manastira nalaze se <a href="/kanjon-jerme/">kanjon reke Jerme</a> sa stazama za pešačenje, <a href="/bazen-zvonacka-banja/">bazeni Zvonačke Banje</a> sa termomineralnom vodom temperature 28°C, greben <a href="/asenovo-kale/">Asenovo Kale</a> na 1032 m nadmorske visine sa gnezdima surih orlova, i pećina Vetrena Dupka sa 4 km podzemnih kanala.
        </p>
      </div>
    </section>

    <section class="attraction-faq">
      <div class="attraction-faq__inner container">
        <h2>Često postavljana pitanja o manastiru Poganovo</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>Kada je osnovan manastir Poganovo?</summary>
            <p>Manastir Poganovo je podignut u 14. veku. Prema predanju, osnivač manastira je srpski plemić iz dinastije Dragaša. Manastir je posvećen Svetom Jovanu Bogoslovu.</p>
          </details>
          <details class="faq-item">
            <summary>Čime je poznat manastir Poganovo?</summary>
            <p>Manastir Poganovo je poznat po izuzetnim freskama iz 14. i 15. veka koje svedoče o bogatoj umetničkoj tradiciji srednjovekovne Srbije. Posebno se ističe freska Sv. Jovana Bogoslova.</p>
          </details>
          <details class="faq-item">
            <summary>Gde se nalazi manastir Poganovo?</summary>
            <p>Manastir Poganovo se nalazi u kanjonu reke Jerme, u neposrednoj blizini Zvonačke Banje, u jugoistočnoj Srbiji (Pirotski okrug). Okružen je stenovitim liticama i gustom vegetacijom.</p>
          </details>
          <details class="faq-item">
            <summary>Kako doći do manastira Poganovo?</summary>
            <p>Do manastira se dolazi regionalnim putem iz pravca Pirota ili Babušnice, dolinom reke Jerme. Manastir je udaljen oko 30 km od Pirota. Put prolazi kroz spektakularan kanjon reke Jerme.</p>
          </details>
          <details class="faq-item">
            <summary>Koji još manastiri postoje u okolini Zvonačke Banje?</summary>
            <p>Pored manastira Poganovo, u okolini se nalaze manastiri Sukovo i Temska. Sva tri manastira zajedno čine dragoceno kulturno-istorijsko nasleđe jugoistočne Srbije.</p>
          </details>
          <details class="faq-item">
            <summary>Da li je manastir Poganovo otvoren za posetioce?</summary>
            <p>Da, manastir Poganovo je otvoren za posetioce tokom cele godine. Manastir je aktivan i u njemu žive monahinje. Posetioci mogu razgledati crkvu, freske i manastirski kompleks.</p>
          </details>
          <details class="faq-item">
            <summary>Šta još mogu posetiti u blizini manastira?</summary>
            <p>U blizini manastira nalaze se kanjon reke Jerme, bazeni Zvonačke Banje sa termomineralnom vodom, greben Asenovo Kale sa gnezdima surih orlova i pećina Vetrena Dupka sa 4 km podzemnih kanala.</p>
          </details>
          <details class="faq-item">
            <summary>Da li postoji parking kod manastira Poganovo?</summary>
            <p>Da, ispred manastira se nalazi parking za posetioce. Prostor je ograničen, pa se tokom praznika i vikenda preporučuje dolazak u ranijim jutarnjim satima.</p>
          </details>
        </div>
      </div>
    </section>

    <RelatedAttractions current="/manastir-poganovo/" />
  </main>
  <Footer />
</BaseLayout>

<style>
  .attraction-hero {
    position: relative;
    width: 100%;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    padding-top: 5em;
    overflow: hidden;
  }

  .attraction-hero__bg {
    position: absolute;
    inset: 0;
    background-color: #2a3a2d;
    background-image: url('/assets/images/card-manastir-poganovo.jpg');
    background-size: cover;
    background-position: center;
  }

  .attraction-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(31,44,34,0.3) 0%, rgba(31,44,34,0.8) 100%);
  }

  .attraction-hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25em;
    padding-block: 4em;
  }

  .attraction-hero__back {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: var(--tracking-ui);
    transition: color var(--transition-base);
  }

  .attraction-hero__back:hover {
    color: var(--color-heading);
  }

  .attraction-hero__title {
    font-size: var(--text-h1);
    line-height: 1.0;
  }

  .attraction-hero__accent {
    font-style: italic;
  }

  .attraction-content {
    width: 100%;
    background-color: var(--color-bg);
    padding-block: var(--spacing-section);
  }

  .attraction-content__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4em;
    align-items: stretch;
  }

  .attraction-content__text {
    display: flex;
    flex-direction: column;
    gap: 1.5em;
  }

  .attraction-content__text p {
    font-size: var(--text-body);
    color: var(--color-text-light);
    line-height: 1.8;
    font-weight: 300;
  }

  .attraction-content__image {
    position: relative;
    border-radius: 0.75em;
    overflow: hidden;
  }

  .attraction-content__image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .attraction-content__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(31, 44, 34, 0.15) 0%, rgba(31, 44, 34, 0.4) 100%);
    pointer-events: none;
  }

  @media (max-width: 991px) {
    .attraction-hero__title {
      font-size: 3em;
    }

    .attraction-content__inner {
      grid-template-columns: 1fr;
      gap: 1.25em;
    }

    .attraction-content__image {
      height: 20em;
    }

    .attraction-content__image img {
      height: 100%;
      object-fit: cover;
    }
  }

  @media (max-width: 767px) {
    .attraction-hero {
      min-height: 60vh;
    }

    .attraction-hero__title {
      font-size: 2.5em;
    }

    .attraction-content__inner {
      gap: 1em;
    }
  }

  .attraction-details {
    width: 100%;
    background-color: var(--color-bg);
    padding-block: 0 var(--spacing-section);
  }

  .attraction-details__inner {
    max-width: 48em;
  }

  .attraction-details__inner h2 {
    font-size: var(--text-h3);
    color: var(--color-heading);
    margin-top: 2.5em;
    margin-bottom: 1em;
    font-weight: 400;
    line-height: 1.3;
  }

  .attraction-details__inner h2:first-child {
    margin-top: 0;
  }

  .attraction-details__inner p {
    font-size: var(--text-body);
    color: var(--color-text-light);
    line-height: 1.8;
    font-weight: 300;
  }

  .attraction-details__inner a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .attraction-faq {
    width: 100%;
    background-color: var(--color-bg-alt, #1a2a1d);
    padding-block: var(--spacing-section);
  }

  .attraction-faq__inner {
    max-width: 48em;
  }

  .attraction-faq__inner > h2 {
    font-size: var(--text-h3);
    color: var(--color-heading);
    margin-bottom: 2em;
    font-weight: 400;
    line-height: 1.3;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
  }

  .faq-item {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .faq-item:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .faq-item summary {
    font-size: var(--text-body);
    color: var(--color-heading);
    font-weight: 500;
    padding: 1.25em 0;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1em;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: "+";
    font-size: 1.25em;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .faq-item[open] summary::after {
    content: "−";
  }

  .faq-item p {
    font-size: var(--text-body);
    color: var(--color-text-light);
    line-height: 1.8;
    font-weight: 300;
    padding-bottom: 1.25em;
  }

  @media (max-width: 479px) {
    .attraction-hero__title {
      font-size: 2em;
    }
  }
</style>
