---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import RelatedAttractions from "../components/RelatedAttractions.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Asenovo Kale — Greben na 1032 m sa gnezdima surih orlova | Zvonačka Banja"
  description="Asenovo Kale je jedino mesto u Srbiji gde se mogu videti gnezda surih orlova. U blizini pećina Vetrena Dupka sa 4 km kanala. Panoramski pogled na Vlašku planinu."
  schema={{
    "@context": "https://schema.org",
    "@type": "TouristAttraction",
    "name": "Asenovo Kale",
    "description": "Greben na nadmorskoj visini od 1032 m, jedino mesto u Srbiji gde se mogu videti gnezda surih orlova. U blizini je pećina Vetrena Dupka sa kanalima dužine 4 km.",
    "url": "https://www.zvonackabanja.net/asenovo-kale/",
    "image": "https://www.zvonackabanja.net/assets/images/card-asenovo-kale.jpg",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Zvonačka Banja",
      "addressRegion": "Pirotski okrug",
      "addressCountry": "RS"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 43.1,
      "longitude": 22.6,
      "elevation": "1032"
    },
    "isPartOf": {
      "@type": "TouristAttraction",
      "name": "Zvonačka Banja",
      "url": "https://www.zvonackabanja.net/"
    }
  }}
  extraSchemas={[
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Početna", "item": "https://www.zvonackabanja.net/" },
        { "@type": "ListItem", "position": 2, "name": "Šta Posetiti", "item": "https://www.zvonackabanja.net/#services" },
        { "@type": "ListItem", "position": 3, "name": "Asenovo Kale", "item": "https://www.zvonackabanja.net/asenovo-kale/" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Šta je Asenovo Kale?",
          "acceptedAnswer": { "@type": "Answer", "text": "Asenovo Kale je greben na nadmorskoj visini od 1032 m u blizini Zvonačke Banje. To je jedino mesto u Srbiji gde se mogu videti gnezda surih orlova. Na grebenu se nalaze i ostaci srednjovekovne tvrđave." }
        },
        {
          "@type": "Question",
          "name": "Zašto je Asenovo Kale jedinstveno u Srbiji?",
          "acceptedAnswer": { "@type": "Answer", "text": "Asenovo Kale je jedino mesto u Srbiji gde gnezde suri orlovi — retka i zaštićena vrsta ptica grabljivica. Nepristupačne litice i mirno okruženje daleko od ljudskih naselja pružaju idealne uslove za gnežđenje." }
        },
        {
          "@type": "Question",
          "name": "Šta je pećina Vetrena Dupka?",
          "acceptedAnswer": { "@type": "Answer", "text": "Vetrena Dupka je pećina u blizini Asenovog Kaleta sa podzemnim kanalima dužine 4 km. Privlači speleologe i ljubitelje prirode impresivnim podzemnim formacijama i predstavlja jednu od najzanimljivijih speleoloških lokacija u jugoistočnoj Srbiji." }
        },
        {
          "@type": "Question",
          "name": "Kako doći do Asenovog Kaleta?",
          "acceptedAnswer": { "@type": "Answer", "text": "Do Asenovog Kaleta se dolazi iz Zvonačke Banje planinarskim stazama. Polazna tačka je banjski kompleks, odakle staza vodi kroz šumu do grebena. Preporučuje se planinarsko iskustvo i odgovarajuća oprema." }
        },
        {
          "@type": "Question",
          "name": "Kakav pogled se pruža sa Asenovog Kaleta?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sa grebena se pruža spektakularan panoramski pogled na okolne planine, dolinu reke Jerme i prostranstva Vlaške planine. Po vedrom vremenu, vidik seže do udaljenih vrhova Stare planine." }
        },
        {
          "@type": "Question",
          "name": "Da li postoje ostaci tvrđave na Asenovom Kaletu?",
          "acceptedAnswer": { "@type": "Answer", "text": "Da, Asenovo Kale je lokalitet sa ostacima srednjovekovne tvrđave, što mu daje dodatnu kulturno-istorijsku vrednost. Tvrđava je služila kao odbrambeno utvrđenje koje je koristilo prirodnu zaštitu strmih litica." }
        },
        {
          "@type": "Question",
          "name": "Šta još posetiti u blizini Asenovog Kaleta?",
          "acceptedAnswer": { "@type": "Answer", "text": "U blizini se nalaze bazeni Zvonačke Banje sa termomineralnom vodom (28°C), kanjon reke Jerme, manastir Poganovo iz 14. veka, i manastiri Sukovo i Temska. Moguće je planinarenje po Vlaškoj i Staroj planini." }
        },
        {
          "@type": "Question",
          "name": "Da li je Asenovo Kale pogodno za početnike?",
          "acceptedAnswer": { "@type": "Answer", "text": "Uspon na Asenovo Kale zahteva određenu fizičku kondiciju jer staza prolazi kroz strm teren. Nije preporučljivo za potpune početnike ili malu decu. Iskusni planinari će uživati u izazovu i spektakularnom pogledu sa vrha." }
        }
      ]
    }
  ]}
>
  <Navbar />
  <main id="main-content">
    <section class="attraction-hero">
      <div class="attraction-hero__bg">
        <div class="attraction-hero__overlay"></div>
      </div>
      <div class="attraction-hero__inner container">
        <a href="/#services" class="attraction-hero__back">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
          Nazad
        </a>
        <span class="eyebrow">Šta Posetiti</span>
        <h1 class="attraction-hero__title">Asenovo<br><span class="attraction-hero__accent">Kale</span></h1>
      </div>
    </section>

    <section class="attraction-content">
      <div class="attraction-content__inner container">
        <div class="attraction-content__text" data-fade-up>
          <p>
            Asenovo Kale je greben na nadmorskoj visini od 1032 m koji je jedino mesto u Srbiji gde se mogu videti gnezda surih orlova. Nalazi se u blizini Zvonačke Banje i nudi spektakularan panoramski pogled na Vlašku planinu, dolinu reke Jerme i okolne planinske vrhove. Na grebenu se nalaze i ostaci srednjovekovne tvrđave.
          </p>
        </div>
        <div class="attraction-content__image" data-reveal>
          <img src="/assets/images/asenovo-kale-content.jpg" alt="Asenovo Kale sa panoramskim pogledom" width="1200" height="800" loading="lazy" />
          <div class="attraction-content__image-overlay"></div>
        </div>
      </div>
    </section>

    <section class="attraction-details">
      <div class="attraction-details__inner container">
        <h2>Zašto je Asenovo Kale jedinstveno u Srbiji?</h2>
        <p>
          Asenovo Kale je jedino mesto u Srbiji gde gnezde suri orlovi — retka i zaštićena vrsta ptica grabljivica sa rasponom krila do 2,5 metra. Nepristupačne litice grebena i mirno okruženje daleko od ljudskih naselja pružaju idealne uslove za gnežđenje ove impresivne ptice. Posmatranje surih orlova u njihovom prirodnom staništu je jedinstveno iskustvo za ljubitelje prirode i ornitologe.
        </p>

        <h2>Šta je pećina Vetrena Dupka?</h2>
        <p>
          Vetrena Dupka je pećina u blizini Asenovog Kaleta sa podzemnim kanalima dužine 4 km. Pećina privlači speleologe i ljubitelje prirode impresivnim podzemnim formacijama — stalaktitima, stalagmitima i podzemnim dvoranama. Predstavlja jednu od najzanimljivijih speleoloških lokacija u jugoistočnoj Srbiji. Za ulazak u pećinu preporučuje se odgovarajuća oprema i iskustvo u speleologiji.
        </p>

        <h2>Kakav pogled se pruža sa grebena?</h2>
        <p>
          Sa vrha Asenovog Kaleta na 1032 m nadmorske visine pruža se spektakularan panoramski pogled na okolne planine, dolinu reke Jerme i prostranstva Vlaške planine. Po vedrom vremenu, vidik seže do udaljenih vrhova Stare planine. Ovo je jedno od najlepših panoramskih mesta u jugoistočnoj Srbiji.
        </p>

        <h2>Da li postoje ostaci srednjovekovne tvrđave?</h2>
        <p>
          Da, Asenovo Kale je lokalitet sa ostacima srednjovekovne tvrđave koja je služila kao odbrambeno utvrđenje. Tvrđava je koristila prirodnu zaštitu strmih litica i kontrolisala pristup dolini reke Jerme. Ostaci zidina su i danas vidljivi i daju grebenu dodatnu kulturno-istorijsku vrednost.
        </p>

        <h2>Kako doći do Asenovog Kaleta?</h2>
        <p>
          Do Asenovog Kaleta se dolazi iz Zvonačke Banje planinarskim stazama. Polazna tačka je banjski kompleks, odakle staza vodi kroz šumu do grebena. Uspon zahteva određenu fizičku kondiciju jer staza prolazi kroz strm teren. U blizini su i staze za planinarenje po Vlaškoj i Staroj planini, te obližnji <a href="/manastir-poganovo/">manastir Poganovo</a>, <a href="/kanjon-jerme/">kanjon Jerme</a> i <a href="/bazen-zvonacka-banja/">bazeni Zvonačke Banje</a>.
        </p>
      </div>
    </section>

    <section class="attraction-faq">
      <div class="attraction-faq__inner container">
        <h2>Često postavljana pitanja o Asenovom Kaletu</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>Šta je Asenovo Kale?</summary>
            <p>Asenovo Kale je greben na nadmorskoj visini od 1032 m u blizini Zvonačke Banje. To je jedino mesto u Srbiji gde se mogu videti gnezda surih orlova. Na grebenu se nalaze i ostaci srednjovekovne tvrđave.</p>
          </details>
          <details class="faq-item">
            <summary>Zašto je Asenovo Kale jedinstveno u Srbiji?</summary>
            <p>Asenovo Kale je jedino mesto u Srbiji gde gnezde suri orlovi — retka i zaštićena vrsta ptica grabljivica. Nepristupačne litice i mirno okruženje daleko od ljudskih naselja pružaju idealne uslove za gnežđenje.</p>
          </details>
          <details class="faq-item">
            <summary>Šta je pećina Vetrena Dupka?</summary>
            <p>Vetrena Dupka je pećina u blizini Asenovog Kaleta sa podzemnim kanalima dužine 4 km. Privlači speleologe i ljubitelje prirode impresivnim podzemnim formacijama i predstavlja jednu od najzanimljivijih speleoloških lokacija u jugoistočnoj Srbiji.</p>
          </details>
          <details class="faq-item">
            <summary>Kako doći do Asenovog Kaleta?</summary>
            <p>Do Asenovog Kaleta se dolazi iz Zvonačke Banje planinarskim stazama. Polazna tačka je banjski kompleks, odakle staza vodi kroz šumu do grebena. Preporučuje se planinarsko iskustvo i odgovarajuća oprema.</p>
          </details>
          <details class="faq-item">
            <summary>Kakav pogled se pruža sa Asenovog Kaleta?</summary>
            <p>Sa grebena se pruža spektakularan panoramski pogled na okolne planine, dolinu reke Jerme i prostranstva Vlaške planine. Po vedrom vremenu, vidik seže do udaljenih vrhova Stare planine.</p>
          </details>
          <details class="faq-item">
            <summary>Da li postoje ostaci tvrđave na Asenovom Kaletu?</summary>
            <p>Da, Asenovo Kale je lokalitet sa ostacima srednjovekovne tvrđave, što mu daje dodatnu kulturno-istorijsku vrednost. Tvrđava je služila kao odbrambeno utvrđenje koje je koristilo prirodnu zaštitu strmih litica.</p>
          </details>
          <details class="faq-item">
            <summary>Šta još posetiti u blizini Asenovog Kaleta?</summary>
            <p>U blizini se nalaze bazeni Zvonačke Banje sa termomineralnom vodom (28°C), kanjon reke Jerme, manastir Poganovo iz 14. veka, i manastiri Sukovo i Temska. Moguće je planinarenje po Vlaškoj i Staroj planini.</p>
          </details>
          <details class="faq-item">
            <summary>Da li je Asenovo Kale pogodno za početnike?</summary>
            <p>Uspon na Asenovo Kale zahteva određenu fizičku kondiciju jer staza prolazi kroz strm teren. Nije preporučljivo za potpune početnike ili malu decu. Iskusni planinari će uživati u izazovu i spektakularnom pogledu sa vrha.</p>
          </details>
        </div>
      </div>
    </section>

    <RelatedAttractions current="/asenovo-kale/" />
  </main>
  <Footer />
</BaseLayout>

<style>
  .attraction-hero {
    position: relative;
    width: 100%;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    padding-top: 5em;
    overflow: hidden;
  }

  .attraction-hero__bg {
    position: absolute;
    inset: 0;
    background-color: #2a3a2d;
    background-image: url('/assets/images/card-asenovo-kale.jpg');
    background-size: cover;
    background-position: center;
  }

  .attraction-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(31,44,34,0.3) 0%, rgba(31,44,34,0.8) 100%);
  }

  .attraction-hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25em;
    padding-block: 4em;
  }

  .attraction-hero__back {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: var(--tracking-ui);
    transition: color var(--transition-base);
  }

  .attraction-hero__back:hover {
    color: var(--color-heading);
  }

  .attraction-hero__title {
    font-size: var(--text-h1);
    line-height: 1.0;
  }

  .attraction-hero__accent {
    font-style: italic;
  }

  .attraction-content {
    width: 100%;
    background-color: var(--color-bg);
    padding-block: var(--spacing-section);
  }

  .attraction-content__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4em;
    align-items: stretch;
  }

  .attraction-content__text {
    display: flex;
    flex-direction: column;
    gap: 1.5em;
  }

  .attraction-content__text p {
    font-size: var(--text-body);
    color: var(--color-text-light);
    line-height: 1.8;
    font-weight: 300;
  }

  .attraction-content__image {
    position: relative;
    border-radius: 0.75em;
    overflow: hidden;
  }

  .attraction-content__image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .attraction-content__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(31, 44, 34, 0.15) 0%, rgba(31, 44, 34, 0.4) 100%);
    pointer-events: none;
  }

  @media (max-width: 991px) {
    .attraction-hero__title {
      font-size: 3em;
    }

    .attraction-content__inner {
      grid-template-columns: 1fr;
      gap: 1.25em;
    }

    .attraction-content__image {
      height: 20em;
    }

    .attraction-content__image img {
      height: 100%;
      object-fit: cover;
    }
  }

  @media (max-width: 767px) {
    .attraction-hero {
      min-height: 60vh;
    }

    .attraction-hero__title {
      font-size: 2.5em;
    }

    .attraction-content__inner {
      gap: 1em;
    }
  }

  .attraction-details {
    width: 100%;
    background-color: var(--color-bg);
    padding-block: 0 var(--spacing-section);
  }

  .attraction-details__inner {
    max-width: 48em;
  }

  .attraction-details__inner h2 {
    font-size: var(--text-h3);
    color: var(--color-heading);
    margin-top: 2.5em;
    margin-bottom: 1em;
    font-weight: 400;
    line-height: 1.3;
  }

  .attraction-details__inner h2:first-child {
    margin-top: 0;
  }

  .attraction-details__inner p {
    font-size: var(--text-body);
    color: var(--color-text-light);
    line-height: 1.8;
    font-weight: 300;
  }

  .attraction-details__inner a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .attraction-faq {
    width: 100%;
    background-color: var(--color-bg-alt, #1a2a1d);
    padding-block: var(--spacing-section);
  }

  .attraction-faq__inner {
    max-width: 48em;
  }

  .attraction-faq__inner > h2 {
    font-size: var(--text-h3);
    color: var(--color-heading);
    margin-bottom: 2em;
    font-weight: 400;
    line-height: 1.3;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
  }

  .faq-item {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .faq-item:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .faq-item summary {
    font-size: var(--text-body);
    color: var(--color-heading);
    font-weight: 500;
    padding: 1.25em 0;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1em;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: "+";
    font-size: 1.25em;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .faq-item[open] summary::after {
    content: "−";
  }

  .faq-item p {
    font-size: var(--text-body);
    color: var(--color-text-light);
    line-height: 1.8;
    font-weight: 300;
    padding-bottom: 1.25em;
  }

  @media (max-width: 479px) {
    .attraction-hero__title {
      font-size: 2em;
    }
  }
</style>
