---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Asenovo Kale | Zvonačka Banja"
  description="Greben Asenovo Kale na 1032 m nadmorske visine, jedino mesto u Srbiji gde se mogu videti gnezda surih orlova. U blizini je pećina Vetrena Dupka."
  schema={{
    "@context": "https://schema.org",
    "@type": "TouristAttraction",
    "name": "Asenovo Kale",
    "description": "Greben na nadmorskoj visini od 1032 m, jedino mesto u Srbiji gde se mogu videti gnezda surih orlova. U blizini je pećina Vetrena Dupka sa kanalima dužine 4 km.",
    "url": "https://www.zvonackabanja.net/asenovo-kale/",
    "image": "https://www.zvonackabanja.net/assets/images/card-asenovo-kale.jpg",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Zvonačka Banja",
      "addressRegion": "Pirotski okrug",
      "addressCountry": "RS"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 43.1,
      "longitude": 22.6,
      "elevation": "1032"
    },
    "isPartOf": {
      "@type": "TouristAttraction",
      "name": "Zvonačka Banja",
      "url": "https://www.zvonackabanja.net/"
    }
  }}
  extraSchemas={[{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Početna", "item": "https://www.zvonackabanja.net/" },
      { "@type": "ListItem", "position": 2, "name": "Šta Posetiti", "item": "https://www.zvonackabanja.net/#services" },
      { "@type": "ListItem", "position": 3, "name": "Asenovo Kale", "item": "https://www.zvonackabanja.net/asenovo-kale/" }
    ]
  }]}
>
  <Navbar />
  <main id="main-content">
    <section class="attraction-hero">
      <div class="attraction-hero__bg">
        <div class="attraction-hero__overlay"></div>
      </div>
      <div class="attraction-hero__inner container">
        <a href="/#services" class="attraction-hero__back">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
          Nazad
        </a>
        <span class="eyebrow">Šta Posetiti</span>
        <h1 class="attraction-hero__title">Asenovo<br><span class="attraction-hero__accent">Kale</span></h1>
      </div>
    </section>

    <section class="attraction-content">
      <div class="attraction-content__inner container">
        <div class="attraction-content__text" data-fade-up>
          <p>
            Greben Asenovo Kale nalazi se na nadmorskoj visini od 1032 m i jedino je mesto u Srbiji gde se mogu videti gnezda surih orlova. Ova retka i zaštićena vrsta ptica ovde gnezdi zahvaljujući nepristupačnim liticama i mirnom okruženju daleko od ljudskih naselja.
          </p>
          <p>
            U blizini se nalazi i atraktivna pećina Vetrena Dupka, sa kanalima dužine 4 km. Pećina privlači speleologe i ljubitelje prirode svojim impresivnim podzemnim formacijama i predstavlja jednu od najzanimljivijih speleoloških lokacija u jugoistočnoj Srbiji.
          </p>
          <p>
            Sa grebena se pruža spektakularan panoramski pogled na okolne planine, dolinu reke Jerme i prostranstva Vlaške planine. Asenovo Kale je i lokalitet sa ostacima srednjovekovne tvrđave, što mu daje dodatnu kulturno-istorijsku vrednost.
          </p>
          <p>
            Postoje mogućnosti za planinarenje po Vlaškoj i Staroj planini, kao i za lov i ribolov u okolini. U neposrednoj blizini nalaze se i srednjovekovni manastiri Poganovo, Sukovo i Temska.
          </p>
        </div>
        <div class="attraction-content__image" data-reveal>
          <img src="/assets/images/asenovo-kale-content.jpg" alt="Asenovo Kale sa panoramskim pogledom" width="1200" height="800" loading="lazy" />
          <div class="attraction-content__image-overlay"></div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .attraction-hero {
    position: relative;
    width: 100%;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    padding-top: 5em;
    overflow: hidden;
  }

  .attraction-hero__bg {
    position: absolute;
    inset: 0;
    background-color: #2a3a2d;
    background-image: url('/assets/images/card-asenovo-kale.jpg');
    background-size: cover;
    background-position: center;
  }

  .attraction-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(31,44,34,0.3) 0%, rgba(31,44,34,0.8) 100%);
  }

  .attraction-hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25em;
    padding-block: 4em;
  }

  .attraction-hero__back {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: var(--tracking-ui);
    transition: color var(--transition-base);
  }

  .attraction-hero__back:hover {
    color: var(--color-heading);
  }

  .attraction-hero__title {
    font-size: var(--text-h1);
    line-height: 1.0;
  }

  .attraction-hero__accent {
    font-style: italic;
  }

  .attraction-content {
    width: 100%;
    background-color: var(--color-bg);
    padding-block: var(--spacing-section);
  }

  .attraction-content__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4em;
    align-items: stretch;
  }

  .attraction-content__text {
    display: flex;
    flex-direction: column;
    gap: 1.5em;
  }

  .attraction-content__text p {
    font-size: var(--text-body);
    color: var(--color-text-light);
    line-height: 1.8;
    font-weight: 300;
  }

  .attraction-content__image {
    position: relative;
    border-radius: 0.75em;
    overflow: hidden;
  }

  .attraction-content__image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .attraction-content__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(31, 44, 34, 0.15) 0%, rgba(31, 44, 34, 0.4) 100%);
    pointer-events: none;
  }

  @media (max-width: 991px) {
    .attraction-hero__title {
      font-size: 3em;
    }

    .attraction-content__inner {
      grid-template-columns: 1fr;
      gap: 1.25em;
    }

    .attraction-content__image {
      height: 20em;
    }

    .attraction-content__image img {
      height: 100%;
      object-fit: cover;
    }
  }

  @media (max-width: 767px) {
    .attraction-hero {
      min-height: 60vh;
    }

    .attraction-hero__title {
      font-size: 2.5em;
    }

    .attraction-content__inner {
      gap: 1em;
    }
  }

  @media (max-width: 479px) {
    .attraction-hero__title {
      font-size: 2em;
    }
  }
</style>
