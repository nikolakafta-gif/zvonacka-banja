---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import RelatedAttractions from "../components/RelatedAttractions.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Bazeni Zvonačka Banja | Olimpijski bazeni sa termomineralnom vodom 28°C"
  description="Dva zatvorena i jedan otvoreni olimpijski bazen sa mineralnom vodom temperature 28°C i protoka 9 l/s. Sportski tereni za košarku, fudbal, odbojku i tenis u srcu kanjona Jerme."
  schema={{
    "@context": "https://schema.org",
    "@type": "SportsActivityLocation",
    "name": "Bazen Zvonačka Banja",
    "description": "Dva zatvorena i jedan otvoreni olimpijski bazen sa mineralnom vodom temperature 28°C. Tereni za košarku, mali fudbal, odbojku i tenis.",
    "url": "https://www.zvonackabanja.net/bazen-zvonacka-banja/",
    "image": "https://www.zvonackabanja.net/assets/images/hero-bazeni-8.jpg",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Zvonačka Banja",
      "addressRegion": "Pirotski okrug",
      "addressCountry": "RS"
    },
    "amenityFeature": [
      { "@type": "LocationFeatureSpecification", "name": "Otvoreni olimpijski bazen" },
      { "@type": "LocationFeatureSpecification", "name": "Dva zatvorena bazena" },
      { "@type": "LocationFeatureSpecification", "name": "Termomineralna voda 28°C" },
      { "@type": "LocationFeatureSpecification", "name": "Sportski tereni" }
    ],
    "isPartOf": {
      "@type": "TouristAttraction",
      "name": "Zvonačka Banja",
      "url": "https://www.zvonackabanja.net/"
    }
  }}
  extraSchemas={[
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Početna", "item": "https://www.zvonackabanja.net/" },
        { "@type": "ListItem", "position": 2, "name": "Šta Posetiti", "item": "https://www.zvonackabanja.net/#services" },
        { "@type": "ListItem", "position": 3, "name": "Bazen Zvonačka Banja", "item": "https://www.zvonackabanja.net/bazen-zvonacka-banja/" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Koja je temperatura vode u bazenima Zvonačke Banje?",
          "acceptedAnswer": { "@type": "Answer", "text": "Termomineralna voda u bazenima Zvonačke Banje ima prirodnu temperaturu od 28°C tokom cele godine. Voda izvire sa protoka od 9 litara u sekundi i koristi se kako za kupanje tako i za piće." }
        },
        {
          "@type": "Question",
          "name": "Koliko bazena ima u Zvonačkoj Banji?",
          "acceptedAnswer": { "@type": "Answer", "text": "Zvonačka Banja ima tri olimpijska bazena: dva zatvorena i jedan otvoreni. Svi bazeni su punjeni termomineralnom vodom koja prirodno izvire na temperaturi od 28°C." }
        },
        {
          "@type": "Question",
          "name": "Koje bolesti se leče u Zvonačkoj Banji?",
          "acceptedAnswer": { "@type": "Answer", "text": "U Zvonačkoj Banji se leče bolesti lokomotornog aparata, nervne bolesti, reumatizam, povišeni krvni pritisak, poremećaji periferne cirkulacije, klimakterične tegobe, menadžerske bolesti i upalne promene na očima." }
        },
        {
          "@type": "Question",
          "name": "Koje terapije se primenjuju u Zvonačkoj Banji?",
          "acceptedAnswer": { "@type": "Answer", "text": "U banjskom kompleksu primenjuju se hidroterapija, elektroterapija, kineziterapija, parafinoterapija i laseroterapija. Postoje i staze zdravlja za pešačenje u prirodi kao deo terapijskog programa." }
        },
        {
          "@type": "Question",
          "name": "Koji sportski tereni postoje u Zvonačkoj Banji?",
          "acceptedAnswer": { "@type": "Answer", "text": "Pored bazena, kompleks nudi terene za košarku, mali fudbal, odbojku i tenis. Sve sportske sadržaje okružuje netaknuta priroda kanjona reke Jerme." }
        },
        {
          "@type": "Question",
          "name": "Da li je voda u bazenima lekovita?",
          "acceptedAnswer": { "@type": "Answer", "text": "Da, voda u bazenima Zvonačke Banje je termomineralna i ima lekovita svojstva. Koristi se za lečenje reumatizma, bolesti lokomotornog aparata i nervnih bolesti. Voda je pogodna i za piće." }
        },
        {
          "@type": "Question",
          "name": "Gde se nalaze bazeni Zvonačke Banje?",
          "acceptedAnswer": { "@type": "Answer", "text": "Bazeni su smešteni u kompleksu nekadašnjeg hotela Mir u Zvonačkoj Banji, u kanjonu reke Jerme, u jugoistočnoj Srbiji, Pirotski okrug. Do banje se dolazi regionalnim putem iz pravca Pirota ili Babušnice." }
        },
        {
          "@type": "Question",
          "name": "Da li bazen radi tokom cele godine?",
          "acceptedAnswer": { "@type": "Answer", "text": "Zatvoreni bazeni su dostupni tokom cele godine zahvaljujući konstantnoj temperaturi termomineralne vode od 28°C. Otvoreni bazen je dostupan u letnjoj sezoni." }
        }
      ]
    }
  ]}
>
  <Navbar />
  <main id="main-content">
    <section class="attraction-hero">
      <div class="attraction-hero__bg">
        <div class="attraction-hero__overlay"></div>
      </div>
      <div class="attraction-hero__inner container">
        <a href="/#services" class="attraction-hero__back">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
          Nazad
        </a>
        <span class="eyebrow">Šta Posetiti</span>
        <h1 class="attraction-hero__title">Bazen Zvonačka<br><span class="attraction-hero__accent">Banja</span></h1>
      </div>
    </section>

    <section class="attraction-content">
      <div class="attraction-content__inner container">
        <div class="attraction-content__text" data-fade-up>
          <p>
            Bazeni Zvonačke Banje čine tri olimpijska bazena: dva zatvorena i jedan otvoreni, punjeni termomineralnom vodom temperature 28°C sa protokom od 9 litara u sekundi. Voda je lekovita i koristi se kako za kupanje, tako i za piće. Kompleks se nalazi u kanjonu reke Jerme, u sklopu nekadašnjeg hotela 'Mir'.
          </p>
        </div>
        <div class="attraction-content__image" data-reveal>
          <img src="/assets/images/hero-bazeni-10.jpg" alt="Otvoreni olimpijski bazen sa mineralnom vodom u Zvonačkoj Banji" width="1200" height="800" loading="lazy" />
          <div class="attraction-content__image-overlay"></div>
        </div>
      </div>
    </section>

    <section class="attraction-details">
      <div class="attraction-details__inner container">
        <h2>Koja je temperatura i sastav vode u bazenima?</h2>
        <p>
          Termomineralna voda u bazenima Zvonačke Banje prirodno izvire na temperaturi od 28°C tokom cele godine. Protok izvora iznosi 9 litara u sekundi. Voda sadrži minerale koji joj daju lekovita svojstva i pogodna je za kupanje i piće. Konstantna temperatura čini zatvorene bazene dostupnim tokom cele godine, dok je otvoreni bazen u funkciji tokom letnje sezone.
        </p>

        <h2>Koje bolesti se leče u Zvonačkoj Banji?</h2>
        <p>
          Lekovita termomineralna voda i vazdušni kvalitet na nadmorskoj visini od 670 metara koriste se za prevenciju i lečenje širokog spektra oboljenja. U Zvonačkoj Banji se leče:
        </p>
        <ul>
          <li>Bolesti lokomotornog aparata</li>
          <li>Nervne bolesti</li>
          <li>Reumatizam</li>
          <li>Povišeni krvni pritisak</li>
          <li>Poremećaji periferne cirkulacije</li>
          <li>Klimakterične tegobe</li>
          <li>Menadžerske bolesti (stres, hronični umor)</li>
          <li>Upalne promene na očima</li>
        </ul>

        <h2>Koje terapije se primenjuju?</h2>
        <p>
          Banjski kompleks primenjuje moderne terapijske tehnike u kombinaciji sa prirodnim lekovitim činiocima. Dostupne terapije uključuju hidroterapiju (kupke i bazeni sa termomineralnom vodom), elektroterapiju, kineziterapiju (lečenje pokretom), parafinoterapiju i laseroterapiju. Program se dopunjuje pešačenjem stazama zdravlja kroz netaknutu prirodu kanjona reke Jerme.
        </p>

        <h2>Koji sportski sadržaji postoje pored bazena?</h2>
        <p>
          Pored tri olimpijska bazena, kompleks nudi terene za košarku, mali fudbal, odbojku i tenis. Sportski sadržaji su smešteni u neposrednom okruženju <a href="/kanjon-jerme/">kanjona reke Jerme</a>, što ih čini jedinstvenim mestom za aktivni odmor u prirodi. U blizini se nalaze i staze za planinarenje po Vlaškoj i Staroj planini.
        </p>

        <h2>Kako doći do bazena Zvonačke Banje?</h2>
        <p>
          Bazeni se nalaze u kompleksu nekadašnjeg hotela 'Mir' u Zvonačkoj Banji, Pirotski okrug, jugoistočna Srbija. Do banje se dolazi regionalnim putevima iz pravca Pirota (udaljenost oko 30 km) ili Babušnice, dolinom reke Jerme. Sam put kroz kanjon je doživljaj za sebe, vožnja prolazi kroz spektakularne predele sa visokim stenovitim liticama. Tokom posete bazenima, ne propustite obilazak <a href="/manastir-poganovo/">manastira Poganovo</a> sa freskama iz XV veka i penjanje na <a href="/asenovo-kale/">Asenovo Kale</a> za panoramski pogled. Za kompletne informacije o svim atrakcijama pogledajte naš <a href="/vodic/">vodič za posetioce</a>.
        </p>
      </div>
    </section>

    <section class="attraction-faq">
      <div class="attraction-faq__inner container">
        <h2>Često postavljana pitanja o bazenima Zvonačke Banje</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>Koja je temperatura vode u bazenima Zvonačke Banje?</summary>
            <div class="faq-item__answer">
              <p>Termomineralna voda u bazenima Zvonačke Banje ima prirodnu temperaturu od 28°C tokom cele godine. Voda izvire sa protoka od 9 litara u sekundi i koristi se kako za kupanje tako i za piće.</p>
            </div>
          </details>
          <details class="faq-item">
            <summary>Koliko bazena ima u Zvonačkoj Banji?</summary>
            <div class="faq-item__answer">
              <p>Zvonačka Banja ima tri olimpijska bazena: dva zatvorena i jedan otvoreni. Svi bazeni su punjeni termomineralnom vodom koja prirodno izvire na temperaturi od 28°C.</p>
            </div>
          </details>
          <details class="faq-item">
            <summary>Koje bolesti se leče u Zvonačkoj Banji?</summary>
            <div class="faq-item__answer">
              <p>U Zvonačkoj Banji se leče bolesti lokomotornog aparata, nervne bolesti, reumatizam, povišeni krvni pritisak, poremećaji periferne cirkulacije, klimakterične tegobe, menadžerske bolesti i upalne promene na očima.</p>
            </div>
          </details>
          <details class="faq-item">
            <summary>Koje terapije se primenjuju u Zvonačkoj Banji?</summary>
            <div class="faq-item__answer">
              <p>U banjskom kompleksu primenjuju se hidroterapija, elektroterapija, kineziterapija, parafinoterapija i laseroterapija. Postoje i staze zdravlja za pešačenje u prirodi kao deo terapijskog programa.</p>
            </div>
          </details>
          <details class="faq-item">
            <summary>Koji sportski tereni postoje u Zvonačkoj Banji?</summary>
            <div class="faq-item__answer">
              <p>Pored bazena, kompleks nudi terene za košarku, mali fudbal, odbojku i tenis. Sve sportske sadržaje okružuje netaknuta priroda kanjona reke Jerme.</p>
            </div>
          </details>
          <details class="faq-item">
            <summary>Da li je voda u bazenima lekovita?</summary>
            <div class="faq-item__answer">
              <p>Da, voda u bazenima Zvonačke Banje je termomineralna i ima lekovita svojstva. Koristi se za lečenje reumatizma, bolesti lokomotornog aparata i nervnih bolesti. Voda je pogodna i za piće.</p>
            </div>
          </details>
          <details class="faq-item">
            <summary>Gde se nalaze bazeni Zvonačke Banje?</summary>
            <div class="faq-item__answer">
              <p>Bazeni su smešteni u kompleksu nekadašnjeg hotela 'Mir' u Zvonačkoj Banji, u kanjonu reke Jerme, u jugoistočnoj Srbiji, Pirotski okrug. Do banje se dolazi regionalnim putem iz pravca Pirota ili Babušnice.</p>
            </div>
          </details>
          <details class="faq-item">
            <summary>Da li bazen radi tokom cele godine?</summary>
            <div class="faq-item__answer">
              <p>Zatvoreni bazeni su dostupni tokom cele godine zahvaljujući konstantnoj temperaturi termomineralne vode od 28°C. Otvoreni bazen je dostupan u letnjoj sezoni.</p>
            </div>
          </details>
        </div>
      </div>
    </section>

    <RelatedAttractions current="/bazen-zvonacka-banja/" />
  </main>
  <Footer />
</BaseLayout>

<style>
  .attraction-hero {
    position: relative;
    width: 100%;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    padding-top: 5em;
    overflow: hidden;
  }

  .attraction-hero__bg {
    position: absolute;
    inset: 0;
    background-color: #2a3a2d;
    background-image: url('/assets/images/hero-bazeni-8.jpg');
    background-size: cover;
    background-position: center;
  }

  .attraction-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(31,44,34,0.3) 0%, rgba(31,44,34,0.8) 100%);
  }

  .attraction-hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25em;
    padding-block: 4em;
  }

  .attraction-hero__back {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: var(--tracking-ui);
    transition: color var(--transition-base);
  }

  .attraction-hero__back:hover {
    color: var(--color-heading);
  }

  .attraction-hero__title {
    font-size: var(--text-h1);
    line-height: 1.0;
  }

  .attraction-hero__accent {
    font-style: italic;
  }

  .attraction-content {
    width: 100%;
    background-color: var(--color-bg);
    padding-block: var(--spacing-section);
  }

  .attraction-content__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5em;
  }

  .attraction-content__text {
    max-width: 48em;
    text-align: center;
  }

  .attraction-content__text p {
    font-size: 1.125em;
    color: var(--color-text-light);
    line-height: 1.8;
    font-weight: 300;
  }

  .attraction-content__image {
    position: relative;
    width: 100%;
    max-width: 52em;
    margin-inline: auto;
    border-radius: 0.75em;
    overflow: hidden;
    aspect-ratio: 16/9;
  }

  .attraction-content__image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .attraction-content__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(31, 44, 34, 0.15) 0%, rgba(31, 44, 34, 0.4) 100%);
    pointer-events: none;
  }

  @media (max-width: 991px) {
    .attraction-hero__title {
      font-size: 3em;
    }

    .attraction-details__inner h2,
    .attraction-faq__inner > h2 {
      font-size: 2em;
    }
  }

  @media (max-width: 767px) {
    .attraction-hero {
      min-height: 60vh;
    }

    .attraction-hero__title {
      font-size: 2.5em;
    }

    .attraction-details__inner h2,
    .attraction-faq__inner > h2 {
      font-size: 1.75em;
    }
  }

  .attraction-details {
    width: 100%;
    background-color: var(--color-bg);
    padding-block: 0 var(--spacing-section);
  }

  .attraction-details__inner {
    max-width: 48em;
    margin-inline: auto;
  }

  .attraction-details__inner h2 {
    font-size: var(--text-h2);
    color: var(--color-heading);
    margin-top: 2.5em;
    margin-bottom: 1em;
    font-weight: 400;
    line-height: 1.3;
  }

  .attraction-details__inner h2:first-child {
    margin-top: 0;
  }

  .attraction-details__inner p {
    font-size: 1.125em;
    color: var(--color-text-light);
    line-height: 1.8;
    font-weight: 300;
  }

  .attraction-details__inner ul {
    list-style: none;
    padding: 0;
    margin-top: 1em;
    display: flex;
    flex-direction: column;
    gap: 0.5em;
  }

  .attraction-details__inner li {
    font-size: 1.125em;
    color: var(--color-text-light);
    line-height: 1.8;
    font-weight: 300;
    padding-left: 1.5em;
    position: relative;
  }

  .attraction-details__inner li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.75em;
    width: 0.375em;
    height: 0.375em;
    border-radius: 50%;
    background-color: var(--color-accent);
  }

  .attraction-faq {
    width: 100%;
    background-color: var(--color-bg-alt, #1a2a1d);
    padding-block: var(--spacing-section);
  }

  .attraction-faq__inner {
    max-width: 48em;
    margin-inline: auto;
  }

  .attraction-faq__inner > h2 {
    font-size: var(--text-h2);
    color: var(--color-heading);
    margin-bottom: 2em;
    font-weight: 500;
    line-height: 1.3;
    text-align: center;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq-item {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .faq-item:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .faq-item summary {
    font-size: 1.125em;
    color: var(--color-heading);
    font-weight: 500;
    padding: 1.25em 0;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1em;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: "+";
    font-size: 1.75em;
    color: var(--color-accent);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .faq-item[open] summary::after {
    content: "−";
  }

  .faq-item__answer {
    overflow: hidden;
  }

  .faq-item p {
    font-size: 1.125em;
    color: var(--color-text-light);
    line-height: 1.8;
    font-weight: 300;
    padding-bottom: 1.25em;
  }

  @media (max-width: 479px) {
    .attraction-hero__title {
      font-size: 2em;
    }

    .attraction-details__inner h2,
    .attraction-faq__inner > h2 {
      font-size: 1.5em;
    }
  }
</style>
